# ── Local development (.env.local) ────────────────────────────────────────────
# Copy this file to .env.local and fill in the values.
# .env.local is gitignored and never committed.

# Gemini API key (required for production AI signals)
# Get one at: https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Google Analytics 4 Measurement ID (optional — enables GA event tracking)
# analytics.google.com → Admin → Data Streams → your web stream → Measurement ID
# Format: G-XXXXXXXXXX
# Without this, events are logged to the browser console in dev mode instead.
VITE_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# Backend URL (leave empty for local dev — defaults to http://localhost:4001)
VITE_API_URL=

# ── GitHub Actions secrets (set in repo Settings → Secrets → Actions) ─────────
#   VITE_API_URL   → your Render service URL, e.g. https://akcnse-api.onrender.com

# ── Render environment variables (set in Render dashboard) ────────────────────
#   NODE_ENV       → production  (set automatically by render.yaml)
#   GEMINI_API_KEY → your Gemini key
#   ALLOWED_ORIGINS→ https://yourusername.github.io
